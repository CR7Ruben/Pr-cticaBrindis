<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1117"
    tools:context=".Login">

    <!-- Card principal centrada -->
    <androidx.cardview.widget.CardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        app:cardBackgroundColor="#1A1D27"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Barra de acento superior (firma del diseño) -->
            <View
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="#6366F1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

                <!-- Ícono / logo -->
                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_icon_circle"
                    android:gravity="center"
                    android:text="PV"
                    android:textColor="#6366F1"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Título -->
                <TextView
                    android:id="@+id/tvTitulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:text="Punto de Venta"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02" />

                <!-- Subtítulo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="6dp"
                    android:text="Inicia sesión para continuar"
                    android:textColor="#8B8FA8"
                    android:textSize="13sp" />

                <!-- Divisor -->
                <View
                    android:layout_width="32dp"
                    android:layout_height="2dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="20dp"
                    android:background="#6366F1" />

                <!-- Campo Usuario -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:hint="Usuario"
                    app:startIconDrawable="@drawable/ic_user"
                    app:startIconTint="#6366F1"
                    app:boxStrokeColor="#6366F1"
                    app:boxStrokeWidthFocused="2dp"
                    app:hintTextColor="#6366F1"
                    app:boxBackgroundColor="#232636"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etUsuario"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="14dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#8B8FA8"
                        android:textSize="15sp"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo Contraseña -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="Contraseña"
                    app:passwordToggleEnabled="true"
                    app:passwordToggleTint="#8B8FA8"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:startIconTint="#6366F1"
                    app:boxStrokeColor="#6366F1"
                    app:boxStrokeWidthFocused="2dp"
                    app:hintTextColor="#6366F1"
                    app:boxBackgroundColor="#232636"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etContrasena"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="14dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#8B8FA8"
                        android:textSize="15sp"
                        android:inputType="textPassword" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Mensaje de error -->
                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text=""
                    android:textColor="#F87171"
                    android:textSize="13sp"
                    android:textAlignment="center" />

                <!-- Botón Entrar -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="20dp"
                    android:text="Entrar"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#6366F1"
                    app:cornerRadius="12dp"
                    app:rippleColor="#4F51C5" />

                <!-- Footer -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="20dp"
                    android:text="© RubencitoSiu 2026"
                    android:textColor="#4A4D60"
                    android:textSize="11sp" />

            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>